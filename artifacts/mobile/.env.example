EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
# Optionnel: utile si Expo genere une mauvaise URL de retour OAuth.
# Exemple Expo Go LAN: exp://192.168.1.18:8082/--/auth/callback
# Exemple build app: samastock://auth/callback
EXPO_PUBLIC_AUTH_REDIRECT_URL=
