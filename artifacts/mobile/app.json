{
  "expo": {
    "name": "SamaStock",
    "slug": "samastock",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/logo1.png",
    "scheme": "samastock",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F8F5"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.samastock.app",
      "versionCode": 5,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo1.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "SamaStock utilise la camera pour scanner les codes-barres des produits."
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "89e6026c-7a9c-497f-9fad-d985e31b34fd"
      }
    }
  }
}
